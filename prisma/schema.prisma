generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Separation {
  id              String   @id @default(cuid())
  userId          String
  originalName    String
  originalSize    Int
  vocalsUrl       String
  instrumentalUrl String
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
